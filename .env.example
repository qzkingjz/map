PORT=3000
HOST_PORT=3000

# Admin database and login settings.
APP_DB_HOST=127.0.0.1
APP_DB_PORT=3306
APP_DB_NAME=qiaoqing_admin
APP_DB_USER=qiaoqing_app
APP_DB_PASSWORD=fjma1234
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=fjma1234
APP_ADMIN_DISPLAY_NAME=系统管理员
APP_SESSION_TTL_HOURS=12
APP_CAPTCHA_TTL_SECONDS=300

# Foundation model for location extraction and coordinate generation.
OPENAI_API_KEY=your-foundation-model-api-key
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_MS=30000
OPENAI_ANSWER_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=0

# Optional: enable RAGFlow for grounded answers and follow-up Q&A.
# Use the RAGFlow chat assistant ID, not the dataset ID.
RAGFLOW_ENABLED=true
RAGFLOW_BASE_URL=http://127.0.0.1
RAGFLOW_API_KEY=ragflow-api-key
RAGFLOW_CHAT_ID=replace-with-ragflow-chat-assistant-id
RAGFLOW_MODEL=ragflow-chat
RAGFLOW_TIMEOUT_MS=60000
RAGFLOW_SESSION_REUSE_ENABLED=true
RAGFLOW_SESSION_TTL_MS=1800000

# Query speed knobs: cache repeated map Q&A and reuse recent results.
QUERY_CACHE_TTL_MS=600000
QUERY_CACHE_MAX_ENTRIES=120
KNOWLEDGE_FALLBACK_DELAY_MS=2500
LOCATION_EXTRACTION_SOFT_TIMEOUT_MS=8000

# Lightweight cleaning for uploaded/imported knowledge text.
DATA_CLEANING_ENABLED=true
DATA_CLEANING_MAX_CHARS=12000
DATA_CLEANING_UPLOAD_MAX_BYTES=5242880
DATA_CLEANING_STORAGE_DIR=data/cleaning-uploads

# Recommended news collection provider.
TAVILY_API_KEY=
TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
TAVILY_TOPIC=general
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_INCLUDE_DOMAINS=chinaqw.com,chinanews.com.cn,fj.chinanews.com.cn,people.com.cn,xinhuanet.com,cctv.com,cnr.cn,cri.cn,gmw.cn,china.com.cn,ce.cn,fjsen.com,qz.fjsen.com,qzwb.com,qztv.cn,hqu.edu.cn
COLLECTION_CRAWLER_TIMEOUT_MS=10000
COLLECTION_TAVILY_TIMEOUT_MS=8000
COLLECTION_BING_TIMEOUT_MS=8000
COLLECTION_GDELT_TIMEOUT_MS=7000
COLLECTION_RSS_TIMEOUT_MS=7000
COLLECTION_SOURCE_FAILURE_THRESHOLD=3
COLLECTION_SOURCE_COOLDOWN_MS=600000

# Optional, recommended for stable news collection.
# Without this key the collector falls back to public sources that may be rate-limited.
BING_NEWS_SEARCH_KEY=
BING_NEWS_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/news/search
BING_NEWS_SEARCH_MARKET=zh-CN
